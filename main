#include <iostream>
#include <vector>
#include <fstream>
#include <algorithm>
#include <iomanip>
#include <set>
using namespace std;

struct Student{
    string id,name;
    vector<pair<string,double>> sub;
};

vector<Student> students;
string fileName="student_data.txt";

// ---------- Average ----------
double avg(Student s){
    double sum=0;
    for(auto x:s.sub) sum+=x.second;
    return s.sub.empty()?0:sum/s.sub.size();
}

// ---------- Save ----------
void saveFile(){
    ofstream fout(fileName);

    for(auto s:students){
        fout<<s.id<<"|"<<s.name<<"|"<<s.sub.size();
        for(auto x:s.sub)
            fout<<"|"<<x.first<<"|"<<x.second;
        fout<<endl;
    }
}

// ---------- Load ----------
void loadFile(){
    ifstream fin(fileName);
    if(!fin) return;

    string line;

    while(getline(fin,line)){
        vector<string> data;
        string temp="";

        for(char ch:line){
            if(ch=='|'){
                data.push_back(temp);
                temp="";
            }else temp+=ch;
        }

        data.push_back(temp);

        if(data.size()<3) continue;

        Student s;
        s.id=data[0];
        s.name=data[1];

        int n=stoi(data[2]),idx=3;

        for(int i=0;i<n;i++){
            if(idx+1>=data.size()) break;
            s.sub.push_back({data[idx],stod(data[idx+1])});
            idx+=2;
        }

        students.push_back(s);
    }
}

// ---------- Check ID ----------
bool foundID(string key){
    for(auto s:students)
        if(s.id==key) return true;
    return false;
}

// ---------- Dynamic Subject List ----------
string chooseSubject(){

    set<string> subjectSet;

    for(auto s:students)
        for(auto x:s.sub)
            subjectSet.insert(x.first);

    if(subjectSet.empty()){
        cout<<"No Subject Found!\n";
        return "";
    }

    vector<string> list(subjectSet.begin(),subjectSet.end());

    cout<<"\n======= Subject List =======\n";

    for(int i=0;i<list.size();i++)
        cout<<i+1<<". "<<list[i]<<endl;

    int ch;
    cout<<"Choose Subject: ";
    cin>>ch;

    if(ch<1 || ch>list.size()) return "";

    return list[ch-1];
}

// ---------- Add ----------
void addStudent(){

    Student s;
    int n;

    cout<<"\n========== Add Student ==========\n";

    cout<<"Enter ID   : ";
    cin>>s.id;

    if(foundID(s.id)){
        cout<<"ID Already Exists!\n";
        return;
    }

    cin.ignore();

    cout<<"Enter Name : ";
    getline(cin,s.name);

    cout<<"Total Subjects: ";
    cin>>n;

    for(int i=1;i<=n;i++){

        string name;
        double mark;

        cin.ignore();

        cout<<"\nSubject "<<i<<" Name : ";
        getline(cin,name);

        cout<<"Marks          : ";
        cin>>mark;

        if(mark<0 || mark>100){
            cout<<"Invalid Marks!\n";
            return;
        }

        s.sub.push_back({name,mark});
    }

    students.push_back(s);
    saveFile();

    cout<<"\nStudent Added Successfully!\n";
}

// ---------- Show ----------
void showAll(){

    if(students.empty()){
        cout<<"No Data Found!\n";
        return;
    }

    cout<<"\n========== Student List ==========\n";

    for(auto s:students){

        cout<<"\nID      : "<<s.id;
        cout<<"\nName    : "<<s.name;
        cout<<"\nSubjects:\n";

        for(auto x:s.sub)
            cout<<"   "
                <<setw(30)<<left
                <<x.first
                <<x.second<<endl;

        cout<<"Average : "
            <<fixed<<setprecision(2)
            <<avg(s)<<endl;

        cout<<"---------------------------------\n";
    }
}

// ---------- Sort ----------
void sortStudent(){

    sort(students.begin(),students.end(),
        [](Student a,Student b){
            return avg(a)>avg(b);
        });

    cout<<"\n===== Sorted By Average =====\n";
    showAll();
}

// ---------- Search ----------
void searchStudent(){

    int op;
    bool found=false;

    cout<<"\n1. Search By ID\n";
    cout<<"2. Search By Name\n";
    cout<<"Choice: ";
    cin>>op;

    string key;

    if(op==1){
        cout<<"Enter ID: ";
        cin>>key;
    }
    else if(op==2){
        cin.ignore();
        cout<<"Enter Name: ";
        getline(cin,key);
    }
    else{
        cout<<"Invalid Choice!\n";
        return;
    }

    cout<<"\n========== Search Result ==========\n";

    for(auto s:students){

        if((op==1 && s.id==key) ||
           (op==2 && s.name==key)){

            cout<<"\nID      : "<<s.id<<endl;
            cout<<"Name    : "<<s.name<<endl;
            cout<<"Subjects:\n";

            for(auto x:s.sub)
                cout<<"   "
                    <<setw(30)<<left
                    <<x.first
                    <<x.second
                    <<endl;

            cout<<"Average : "
                <<fixed<<setprecision(2)
                <<avg(s)<<endl;

            cout<<"---------------------------\n";

            found=true;
        }
    }

    if(!found)
        cout<<"Not Found!\n";
}
// ---------- Update ----------
void updateStudent(){

    string key;

    cout<<"Enter ID: ";
    cin>>key;

    for(auto &s:students)
        if(s.id==key){

            cin.ignore();

            cout<<"New Name: ";
            getline(cin,s.name);

            for(auto &x:s.sub){
                cout<<x.first<<" Marks: ";
                cin>>x.second;
            }

            saveFile();

            cout<<"Updated Successfully!\n";
            return;
        }

    cout<<"ID Not Found!\n";
}

// ---------- Delete ----------
void deleteStudent(){

    string key;

    cout<<"Enter ID: ";
    cin>>key;

    auto old=students.size();

    students.erase(
        remove_if(students.begin(),students.end(),
        [&](Student s){
            return s.id==key;
        }),
        students.end()
    );

    if(students.size()<old){
        saveFile();
        cout<<"Deleted Successfully!\n";
    }
    else cout<<"ID Not Found!\n";
}

// ---------- Subject Menu ----------
void subjectMenu(){

    int ch;

    do{
        cout<<"\n========== Subject Menu ==========\n";
        cout<<"1. subject wise all student mark\n";
        cout<<"2. Highest Marks\n";
        cout<<"3. Average Marks\n";
        cout<<"4. Fail Students\n";
        cout<<"5. Marks Range Search\n";
        cout<<"0. Back\n";
        cout<<"Choice: ";
        cin>>ch;

        if(ch==0) return;

        string subject=chooseSubject();

        if(subject=="") return;

  //subject wise all student mark
        if(ch==1){

    vector<pair<string,double>> list;

    for(auto s:students)
        for(auto x:s.sub)
            if(x.first==subject)
                list.push_back({s.name,x.second});

    sort(list.begin(),list.end(),
        [](auto a,auto b){
            return a.second>b.second;
        });

    cout<<"\n===== "<<subject<<" Ranking =====\n";

    for(int i=0;i<list.size();i++)
        cout<<i+1<<". "
            <<setw(30)<<left
            <<list[i].first
            <<list[i].second
            <<endl;

    if(list.empty())
        cout<<"No Data Found!\n";
}

        // Highest
        if(ch==2){

            string best="";
            double mx=-1;

            for(auto s:students)
                for(auto x:s.sub)
                    if(x.first==subject &&
                       x.second>mx){
                        mx=x.second;
                        best=s.name;
                    }

            cout<<"\nTop Student In "<<subject<<"\n";
            cout<<"Name  : "<<best<<endl;
            cout<<"Marks : "<<mx<<endl;
        }

        // Average
        else if(ch==3){

            double sum=0;
            int c=0;

            for(auto s:students)
                for(auto x:s.sub)
                    if(x.first==subject){
                        sum+=x.second;
                        c++;
                    }

            cout<<"\nSubject : "<<subject<<endl;
            cout<<"Average : "<<sum/c<<endl;
        }

        // Fail
        else if(ch==4){

            bool found=false;

            cout<<"\nFail Students In "<<subject<<"\n";

            for(auto s:students)
                for(auto x:s.sub)
                    if(x.first==subject &&
                       x.second<40){

                        cout<<"- "
                            <<s.name
                            <<" = "
                            <<x.second
                            <<endl;

                        found=true;
                    }

            if(!found)
                cout<<"No Fail Student.\n";
        }

        // Range
        else if(ch==5){

            double low,high;
            int c=0;

            cout<<"Enter Range: ";
            cin>>low>>high;

            cout<<"\nStudents Between "
                <<low<<" - "<<high
                <<" In "<<subject<<"\n";

            for(auto s:students)
                for(auto x:s.sub)
                    if(x.first==subject &&
                       x.second>=low &&
                       x.second<=high){

                        cout<<++c<<". "
                            <<s.name
                            <<" = "
                            <<x.second
                            <<endl;
                    }

            if(c==0)
                cout<<"No Student Found!\n";
        }

    }while(true);
}
// ---------- Compare Sorting ----------
void compareSort() {

    if (students.empty()) {
        cout << "No Data Found!\n";
        return;
    }

    vector<Student> a = students;
    vector<Student> b = students;

    clock_t start, end;

    // Bubble Sort
    start = clock();

    for (int i = 0; i < a.size() - 1; i++) {
        for (int j = 0; j < a.size() - i - 1; j++) {

            if (avg(a[j]) < avg(a[j + 1])) {
                swap(a[j], a[j + 1]);
            }
        }
    }

    end = clock();

    double bubbleTime =
        double(end - start) / CLOCKS_PER_SEC;

    // STL Sort
    start = clock();

    sort(b.begin(), b.end(),
        [](Student x, Student y) {
            return avg(x) > avg(y);
        });

    end = clock();

    double stlTime =
        double(end - start) / CLOCKS_PER_SEC;

    // Output
    cout << "\n====== Sort Comparison ======\n";
    cout << "Bubble Sort Time : "
         << bubbleTime
         << " sec\n";

    cout << "STL Sort Time    : "
         << stlTime
         << " sec\n";

    if (bubbleTime > stlTime)
        cout << "Winner : STL Sort Faster\n";
    else
        cout << "Winner : Bubble Sort Faster\n";
}

// ---------- Main ----------
int main(){

    loadFile();

    int ch;

    do{
        cout<<"\n=================================\n";
        cout<<"      STUDENT ORGANIZER SYSTEM   \n";
        cout<<"=================================\n";
        cout<<"1. Add Student\n";
        cout<<"2. Show All Students\n";
        cout<<"3. Sort By Average\n";
        cout<<"4. Search Student\n";
        cout<<"5. Update Student\n";
        cout<<"6. Delete Student\n";
        cout<<"7. Subject Menu\n";
        cout<<"8. Compare Sorting\n";
        cout<<"0. Exit\n";
        cout<<"---------------------------------\n";
        cout<<"Enter Choice: ";
        cin>>ch;

        switch(ch){
            case 1:addStudent(); break;
            case 2:showAll(); break;
            case 3:sortStudent(); break;
            case 4:searchStudent(); break;
            case 5:updateStudent(); break;
            case 6:deleteStudent(); break;
            case 7:subjectMenu(); break;
            case 8:compareSort(); break;
            case 0:cout<<"Program Ended.\n"; break;
            default:cout<<"Invalid Choice!\n";
        }

    }while(ch!=0);

    return 0;
}


